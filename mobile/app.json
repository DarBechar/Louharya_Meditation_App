{
  "expo": {
    "name": "Louharya",
    "slug": "louharya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0F2E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.louharya.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A0F2E"
      },
      "package": "com.louharya.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "scheme": "louharya",
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}
