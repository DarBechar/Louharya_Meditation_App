{
  "name": "louharya",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "turbo run dev --filter=mobile",
    "dev:api": "turbo run dev --filter=api",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "build:web": "npm run build --workspace=packages/shared && cd apps/mobile && npx expo export -p web"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "react-dom": "^18.2.0",
    "react-native-web": "^0.21.2"
  }
}
